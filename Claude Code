<script>
  // HAMBURGER
  document.getElementById('hamburger').addEventListener('click', function() {
    document.getElementById('navLinks').classList.toggle('open');
  });

  // TABS
  function showTab(btn, tabId) {
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
    document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById(tabId).classList.add('active');
  }

  // ACCORDION
  function toggleAcc(btn) {
    const content = btn.nextElementSibling;
    const isOpen = btn.classList.contains('open');
    document.querySelectorAll('.acc-btn.open').forEach(b => {
      b.classList.remove('open');
      b.nextElementSibling.classList.remove('open');
    });
    if (!isOpen) {
      btn.classList.add('open');
      content.classList.add('open');
    }
  }

  // BUSCADOR
  const searchData = [
    { t: 'Emergencias médicas — llamar al 107 (SAME)', s: '#contactos' },
    { t: 'Vacunas gratuitas — Calendario Nacional', s: '#vacunas' },
    { t: 'Hospitales públicos CABA', s: '#hospitales' },
    { t: 'Programa REMEDIAR — medicamentos gratis', s: '#programas' },
    { t: 'Programa Sumar — embarazadas y niños sin obra social', s: '#programas' },
    { t: 'Salud mental gratuita — Ley 26.657', s: '#programas' },
    { t: 'Maternidad y parto gratuito en hospitales', s: '#programas' },
    { t: 'Derechos del paciente — Ley 26.529', s: '#derechos' },
    { t: 'Hospital Garrahan — pediatría', s: '#hospitales' },
    { t: 'Turnos online hospitales Buenos Aires', s: '#hospitales' },
    { t: 'Diabetes — insulina e insumos gratuitos (PRODIM)', s: '#programas' },
    { t: 'Oncología — Hospital Roffo', s: '#hospitales' },
    { t: 'Vacuna antigripal gratuita', s: '#vacunas' },
    { t: 'Salud visual — anteojos gratuitos', s: '#programas' },
    { t: 'Violencia de género — Línea 144', s: '#contactos' },
    { t: 'Negativa de atención — cómo reclamar', s: '#derechos' },
    { t: 'CeSAC — centros de salud barriales', s: '#atencion' },
    { t: 'VPH — vacuna gratuita para niñas y niños', s: '#vacunas' },
    { t: 'COVID-19 vacuna gratuita', s: '#vacunas' },
    { t: 'Hospital Posadas — Morón, alta complejidad', s: '#hospitales' },
  ];

  function buscar() {
    const q = document.getElementById('searchInput').value.toLowerCase().trim();
    const ul = document.getElementById('search-results');
    if (!q) { ul.style.display = 'none'; return; }
    const res = searchData.filter(d => d.t.toLowerCase().includes(q));
    if (!res.length) {
      ul.innerHTML = '<li style="color:var(--gris); cursor:default;">Sin resultados. Probá con otras palabras.</li>';
    } else {
      ul.innerHTML = res.map(d => `<li onclick="irA('${d.s}')">🔍 ${d.t}</li>`).join('');
    }
    ul.style.display = 'block';
  }

  function irA(selector) {
    document.getElementById('search-results').style.display = 'none';
    document.getElementById('searchInput').value = '';
    document.querySelector(selector)?.scrollIntoView({ behavior: 'smooth' });
  }

  document.getElementById('searchInput').addEventListener('keydown', function(e) {
    if (e.key === 'Enter') buscar();
  });

  // Cerrar búsqueda al hacer clic fuera
  document.addEventListener('click', function(e) {
    if (!e.target.closest('.search-bar') && !e.target.closest('#search-results')) {
      document.getElementById('search-results').style.display = 'none';
    }
  });

  // SMOOTH SCROLL nav
  document.querySelectorAll('a[href^="#"]').forEach(a => {
    a.addEventListener('click', function(e) {
      const t = document.querySelector(this.getAttribute('href'));
      if (t) { e.preventDefault(); t.scrollIntoView({ behavior: 'smooth' }); }
      document.getElementById('navLinks').classList.remove('open');
    });
  });
</script>
