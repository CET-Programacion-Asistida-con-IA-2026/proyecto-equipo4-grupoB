// ===== APLICAR PREFS A11Y =====
function aplicarA11y() {
  document.documentElement.style.setProperty('--text-scale', a11yPrefs.textScale);
  if (a11yPrefs.contrast) {
    document.body.classList.add('high-contrast');
    document.getElementById('contrastBtn').classList.add('active');
  }
  var scale = a11yPrefs.textScale;
  ['tsSmall','tsMed','tsLarge'].forEach(function(id) { document.getElementById(id).classList.remove('active'); });
  if (scale <= 1) document.getElementById('tsSmall').classList.add('active');
  else if (scale <= 1.15) document.getElementById('tsMed').classList.add('active');
  else document.getElementById('tsLarge').classList.add('active');
}
aplicarA11y();

function toggleContrast() {
  a11yPrefs.contrast = !a11yPrefs.contrast;
  document.body.classList.toggle('high-contrast', a11yPrefs.contrast);
  document.getElementById('contrastBtn').classList.toggle('active', a11yPrefs.contrast);
  localStorage.setItem('auxiliar_a11y', JSON.stringify(a11yPrefs));
}

function setTextSize(scale) {
  a11yPrefs.textScale = scale;
  document.documentElement.style.setProperty('--text-scale', scale);
  ['tsSmall','tsMed','tsLarge'].forEach(function(id) { document.getElementById(id).classList.remove('active'); });
  if (scale <= 1) document.getElementById('tsSmall').classList.add('active');
  else if (scale <= 1.15) document.getElementById('tsMed').classList.add('active');
  else document.getElementById('tsLarge').classList.add('active');
  localStorage.setItem('auxiliar_a11y', JSON.stringify(a11yPrefs));
}

// ===== TTS =====
function toggleTTS() {
  if (ttsActivo) {
    window.speechSynthesis.cancel();
    ttsActivo = false;
    document.getElementById('ttsBtn').classList.remove('active');
    document.getElementById('ttsBtnLabel').textContent = 'Leer sección';
    return;
  }
  var secciones = document.querySelectorAll('[data-section]');
  var visible = null;
  var maxVis = 0;
  secciones.forEach(function(sec) {
    var r = sec.getBoundingClientRect();
    var vis = Math.min(r.bottom, window.innerHeight) - Math.max(r.top, 0);
    if (vis > maxVis) { maxVis = vis; visible = sec; }
  });
  if (!visible) return;
  var texto = visible.innerText.replace(/\n+/g, ' ').replace(/\s+/g, ' ').trim();
  ttsUtterance = new SpeechSynthesisUtterance(texto);
  ttsUtterance.lang = 'es-AR';
  ttsUtterance.rate = 0.95;
  ttsUtterance.onend = function() {
    ttsActivo = false;
    document.getElementById('ttsBtn').classList.remove('active');
    document.getElementById('ttsBtnLabel').textContent = 'Leer sección';
  };
  window.speechSynthesis.speak(ttsUtterance);
  ttsActivo = true;
  document.getElementById('ttsBtn').classList.add('active');
  document.getElementById('ttsBtnLabel').textContent = 'Detener';
}

