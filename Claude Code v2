function toggleAcc(btn) {
  var content = btn.nextElementSibling;
  var isOpen = btn.classList.contains('open');
  var container = btn.closest('.accordion') || btn.closest('.pa-category');
  if (container) {
    container.querySelectorAll('.acc-btn.open').forEach(function(b){ b.classList.remove('open'); if(b.nextElementSibling) b.nextElementSibling.classList.remove('open'); });
  }
  if (!isOpen) { btn.classList.add('open'); content.classList.add('open'); }
}

