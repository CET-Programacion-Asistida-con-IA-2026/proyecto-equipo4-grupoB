function iniciarFlujo(flujo) {
  flujoActual = flujo;
  document.getElementById('onboarding').style.display = 'none';
  document.getElementById('app').style.display = 'block';
  var t = textos[flujo];
  document.getElementById('flowTitle').textContent = t.title;
  document.getElementById('flowSubtitle').textContent = t.subtitle;
  ['atencion','hospitales','programas','pa','ongs','derechos','contactos'].forEach(function(k) {
    var tel = document.getElementById('titulo-'+k);
    var sel = document.getElementById('sub-'+k);
    if (tel && t['titulo_'+k]) tel.textContent = t['titulo_'+k];
    if (sel && t['sub_'+k]) sel.textContent = t['sub_'+k];
  });
  var secContrib = document.getElementById('sec-contribuir');
  if (flujo === 'contribuir') secContrib.style.display = 'block';
  else secContrib.style.display = 'none';
  mostrarPerfilBanner();
  initTest();
  window.scrollTo(0,0);
}

function volverOnboarding(e) {
  if (e) e.preventDefault();
  if (ttsActivo) { window.speechSynthesis.cancel(); ttsActivo = false; document.getElementById('ttsBtn').classList.remove('active'); document.getElementById('ttsBtnLabel').textContent = 'Leer sección'; }
  document.getElementById('onboarding').style.display = 'flex';
  document.getElementById('app').style.display = 'none';
  window.scrollTo(0,0);
}

function navTo(e, sec) {
  e.preventDefault();
  document.getElementById('navLinks').classList.remove('open');
  if (document.getElementById('app').style.display === 'none' || !flujoActual) iniciarFlujo('necesito');
  setTimeout(function() {
    var el = document.getElementById('sec-'+sec) || document.querySelector('[data-section="'+sec+'"]');
    if (el) el.scrollIntoView({ behavior: 'smooth' });
  }, 100);
}

// ===== PERFIL =====
function mostrarPerfilBanner() {
  var banner = document.getElementById('perfilBanner');
  if (perfil.provincia || perfil.grupo) {
    var txt = '';
    if (perfil.provincia) txt += perfil.provincia;
    if (perfil.grupo) txt += (txt ? ' · ' : '') + perfil.grupo;
    if (perfil.condicion && perfil.condicion !== 'Ninguna en particular') txt += ' · ' + perfil.condicion;
    document.getElementById('perfilResumen').textContent = txt;
    document.getElementById('perfilEditBtn').style.display = 'inline';
    document.getElementById('perfilEditBtn').textContent = 'Editar perfil';
    banner.style.display = 'flex';
  } else {
    document.getElementById('perfilResumen').textContent = 'Personalizá tu experiencia';
    document.getElementById('perfilEditBtn').style.display = 'inline';
    document.getElementById('perfilEditBtn').textContent = 'Configurar perfil';
    banner.style.display = 'flex';
  }
}

function abrirModal() {
  document.getElementById('sel-provincia').value = perfil.provincia || '';
  document.getElementById('sel-grupo').value = perfil.grupo || '';
  document.getElementById('sel-condicion').value = perfil.condicion || '';
  document.getElementById('perfilModal').classList.add('open');
}

function cerrarModal() {
  document.getElementById('perfilModal').classList.remove('open');
}

function guardarPerfil() {
  perfil.provincia = document.getElementById('sel-provincia').value;
  perfil.grupo = document.getElementById('sel-grupo').value;
  perfil.condicion = document.getElementById('sel-condicion').value;
  localStorage.setItem('auxiliar_perfil', JSON.stringify(perfil));
  cerrarModal();
  mostrarPerfilBanner();
}

