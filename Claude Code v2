var testIdx = 0, testScore = 0, testAnswered = false;

function initTest() {
  testIdx = 0; testScore = 0; testAnswered = false;
  renderQuestion();
}

function renderQuestion() {
  if (testIdx >= preguntas.length) {
    showResult(); return;
  }
  var p = preguntas[testIdx];
  document.getElementById('testCounter').textContent = 'Pregunta ' + (testIdx+1) + ' de ' + preguntas.length;
  document.getElementById('testBar').style.width = (testIdx / preguntas.length * 100) + '%';
  document.getElementById('testQ').textContent = p.q;
  document.getElementById('testOpts').innerHTML = p.opts.map(function(o,i){
    return '<button class="test-opt" onclick="responder('+i+')" aria-label="Opción: '+o+'">'+o+'</button>';
  }).join('');
  var fb = document.getElementById('testFeedback');
  fb.style.display = 'none'; fb.textContent = '';
  document.getElementById('testNext').style.display = 'none';
  testAnswered = false;
}

function responder(idx) {
  if (testAnswered) return;
  testAnswered = true;
  var p = preguntas[testIdx];
  var opts = document.querySelectorAll('.test-opt');
  opts.forEach(function(o){ o.disabled = true; });
  var fb = document.getElementById('testFeedback');
  if (idx === p.ok) {
    opts[idx].classList.add('correct');
    fb.className = 'test-feedback ok';
    fb.textContent = '✓ Correcto. ' + p.ex;
    testScore++;
  } else {
    opts[idx].classList.add('wrong');
    opts[p.ok].classList.add('correct');
    fb.className = 'test-feedback nok';
    fb.textContent = '✗ Incorrecto. ' + p.ex;
  }
  fb.style.display = 'block';
  document.getElementById('testNext').style.display = 'block';
  document.getElementById('testNext').textContent = testIdx < preguntas.length - 1 ? 'Siguiente →' : 'Ver resultados';
}

function nextQuestion() {
  testIdx++;
  renderQuestion();
}

function showResult() {
  var pct = Math.round(testScore / preguntas.length * 100);
  var msg = pct >= 80 ? '¡Muy bien! Tenés buenos conocimientos de primeros auxilios.' : pct >= 50 ? 'Bien. Repasá las secciones donde te equivocaste para estar mejor preparado.' : 'Te recomendamos releer las guías de primeros auxilios de arriba. Puede marcar la diferencia en una emergencia.';
  document.getElementById('testCard').innerHTML =
    '<div style="text-align:center;padding:1rem 0;">' +
    '<div style="font-size:3rem;font-weight:800;font-family:var(--font-title);color:var(--verde);">' + testScore + '/' + preguntas.length + '</div>' +
    '<div style="font-size:1rem;color:var(--gris);margin:0.5rem 0 1rem;">' + pct + '% correcto</div>' +
    '<p style="font-size:0.88rem;color:var(--gris-oscuro);max-width:360px;margin:0 auto 1.5rem;">' + msg + '</p>' +
    '<button class="btn-next" onclick="initTest()" style="margin:0 auto;display:block;">Reiniciar test</button>' +
    '</div>';
}

